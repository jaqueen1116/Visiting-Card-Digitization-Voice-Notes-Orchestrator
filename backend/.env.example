# API Server Configuration
PORT=8000
ENVIRONMENT=development
LOG_LEVEL=INFO

# Database Connection (MongoDB Atlas)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority&appName=Cluster0
MONGODB_DB_NAME=krid_db

# Google Sheets Configuration
# The ID of the spreadsheet used as the primary database
GOOGLE_SHEETS_ID=your-google-sheet-id
# Base64-encoded Service Account Credentials JSON
GOOGLE_APPLICATION_CREDENTIALS=service-account.json

# WhatsApp Business Cloud API Settings
WHATSAPP_PHONE_NUMBER_ID=your-whatsapp-phone-number-id
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token
WHATSAPP_MANAGER_PHONE=your-manager-phone-number-e164-format

# Google Gemini API Settings (for Vision Extraction and Audio Transcription)
GEMINI_API_KEY=your-gemini-api-key

# AI Provider Configuration (Options: gemini, groq)
AI_PROVIDER=gemini
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile
